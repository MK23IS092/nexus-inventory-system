{
  "version": 2,
  "builds": [
    {
      "src": "frontend-react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      },
      "env": {
        "REACT_APP_API_BASE_URL": "https://nexus-inventory-system-production.up.railway.app"
      }
    }
  ],
  "buildCommand": "cd frontend-react && npm run build",
  "outputDirectory": "frontend-react/build",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
