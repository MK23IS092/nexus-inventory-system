{
  "buildCommand": "cd frontend-react && npm ci && npm run build",
  "outputDirectory": "frontend-react/build",
  "installCommand": "cd frontend-react && npm ci",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_BASE_URL": "https://nexus-inventory-system-production.up.railway.app"
  }
}
